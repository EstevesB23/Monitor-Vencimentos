# Quantos dias antes do vencimento o alerta deve ser enviado
DIAS_ALERTA=3

# Credenciais do e-mail remetente
EMAIL_REMETENTE=seu_email@gmail.com
EMAIL_SENHA=sua_senha_de_app

# E-mail que vai receber os alertas
EMAIL_DESTINATARIO=destinatario@email.com

# Configurações SMTP (padrão: Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
